---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import StructuredData from '../components/StructuredData.astro';
import { absolutePageUrl, absoluteUrl, siteConfig } from '../config/site';
import { buildBreadcrumbSchema, type BreadcrumbItem, type StructuredData as StructuredDataType } from '../utils/seo';

interface SocialImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface Props {
  title: string;
  description: string;
  contentType?: 'website' | 'article';
  image?: SocialImage;
  publishedDate?: Date;
  updatedDate?: Date;
  breadcrumbs?: BreadcrumbItem[];
  structuredData?: StructuredDataType | StructuredDataType[];
}

const {
  title,
  description,
  contentType = 'website',
  image = { src: '/og-image.svg', alt: 'Engineering Maker Lab', width: 1200, height: 630 },
  publishedDate,
  updatedDate,
  breadcrumbs = [],
  structuredData = [],
} = Astro.props;
const { googleSiteVerification } = siteConfig.integrations;
const canonicalURL = absolutePageUrl(Astro.url.pathname);
const socialImageURL = absoluteUrl(image.src);
const structuredDataItems = [
  ...(Array.isArray(structuredData) ? structuredData : [structuredData]),
  ...(breadcrumbs.length >= 2 ? [buildBreadcrumbSchema(breadcrumbs)] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content={contentType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={image.alt} />
    <meta property="og:image:width" content={String(image.width)} />
    <meta property="og:image:height" content={String(image.height)} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={image.alt} />
    <meta property="og:site_name" content="Engineering Maker Lab" />
    <meta name="robots" content="index,follow" />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <title>{title}</title>
    {structuredDataItems.map((data) => <StructuredData data={data} />)}
    <Analytics />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
