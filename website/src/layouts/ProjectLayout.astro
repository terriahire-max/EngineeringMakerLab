---
import type { CollectionEntry } from 'astro:content';
import PageLayout from './PageLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CircuitDiagramPlaceholder from '../components/CircuitDiagramPlaceholder.astro';
import CodeExample from '../components/CodeExample.astro';
import FAQ from '../components/FAQ.astro';
import PartsList from '../components/PartsList.astro';
import ProjectHero from '../components/ProjectHero.astro';
import ProjectSection from '../components/ProjectSection.astro';
import ProjectVisual from '../components/ProjectVisual.astro';
import RecommendedKit from '../components/RecommendedKit.astro';
import RelatedProjects from '../components/RelatedProjects.astro';
import Troubleshooting from '../components/Troubleshooting.astro';
import OfficialResources from '../components/OfficialResources.astro';
import ProjectCompletionCTA from '../components/ProjectCompletionCTA.astro';
import Icon from '../components/design-system/Icon.astro';
import Button from '../components/design-system/Button.astro';
import { productById } from '../data/products';
import { buildArticleSchema, buildProductSchema, type BreadcrumbItem } from '../utils/seo';

interface Props {
  project: CollectionEntry<'projects'>;
  kitProjects: CollectionEntry<'projects'>[];
  previousProject?: CollectionEntry<'projects'>;
  nextProject?: CollectionEntry<'projects'>;
}

const { project, previousProject, nextProject } = Astro.props;
const { data } = project;
const pageTitle = `${data.title} Project | Engineering Maker Lab`;
const recommendedProduct = productById.get(data.recommendedProductId);
const projectPath = `/projects/${project.id}`;
const breadcrumbs: BreadcrumbItem[] = [{ label: 'Home', href: '/' }, { label: 'Projects', href: '/projects' }, { label: data.title }];
if (!recommendedProduct) throw new Error(`Project "${project.id}" references unknown product "${data.recommendedProductId}".`);
const articleSchema = buildArticleSchema({ title: data.title, description: data.description, path: projectPath, image: data.featuredImage.src, publishedDate: data.publishedDate, updatedDate: data.updatedDate, section: 'Electronics Projects', tags: data.tags });
const socialImage = data.featuredImage.src ? { src: data.featuredImage.src, alt: data.featuredImage.alt, width: data.featuredImage.width, height: data.featuredImage.height } : undefined;
---

<PageLayout title={pageTitle} description={data.description} contentType="article" image={socialImage} publishedDate={data.publishedDate} updatedDate={data.updatedDate} breadcrumbs={breadcrumbs} structuredData={[articleSchema, buildProductSchema(recommendedProduct)]}>
  <article>
    <ProjectHero project={data} breadcrumbs={breadcrumbs} />

    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8"><RecommendedKit product={recommendedProduct} /></div>

    <div class="mx-auto max-w-4xl space-y-12 px-4 py-14 sm:px-6 lg:px-8">
      <ProjectSection id="build" eyebrow="Project overview" title="What You Will Build">
        <div class="article-content"><slot /></div>
      </ProjectSection>

      {data.visuals?.finished && <ProjectSection id="finished" eyebrow="The result" title="Finished Project"><ProjectVisual {...data.visuals.finished} caption="Finished project reference" /></ProjectSection>}

      <ProjectSection id="learn" eyebrow="Skills" title="What You Will Learn">
        <ul class="grid gap-4 sm:grid-cols-2">{data.learningGoals.map((goal) => <li class="flex gap-3 rounded-2xl border border-blue-100 bg-blue-50/60 p-4 text-sm font-medium leading-6 text-slate-800"><span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-700 text-white"><Icon name="check" size={14} /></span>{goal}</li>)}</ul>
      </ProjectSection>

      <ProjectSection id="parts" eyebrow="Preparation" title="Parts Used" description="Gather these components before starting the build."><PartsList parts={data.parts} /></ProjectSection>

      {data.teacherTip && <ProjectSection id="teacher-tip" eyebrow="Engineering insight" title="Engineering Teacher Tip"><div class="rounded-2xl border border-orange-200 bg-orange-50 p-6 leading-7 text-slate-800">{data.teacherTip}</div></ProjectSection>}

      {data.officialGuide && <ProjectSection id="official-guide" eyebrow="For kit owners" title={data.officialGuide.title} description={data.officialGuide.description}><Button href={data.officialGuide.href} target="_blank" rel="noopener noreferrer" variant="secondary" ariaLabel={`${data.officialGuide.buttonLabel} (opens in a new tab)`}>{data.officialGuide.buttonLabel}</Button></ProjectSection>}

      {!data.officialGuide && data.officialResources && <ProjectSection id="official-resources" eyebrow="Vendor guidance" title="Official Resources" description="These vendor resources provide the complete kit-specific walkthrough."><OfficialResources resources={data.officialResources} /></ProjectSection>}

      {data.visuals?.breadboard && <ProjectSection id="breadboard" eyebrow="Wiring" title="Breadboard Wiring"><ProjectVisual {...data.visuals.breadboard} caption="Simplified original breadboard wiring layout" /></ProjectSection>}

      {data.circuit && <ProjectSection id="circuit" eyebrow="Wiring" title="Circuit Diagram" description={data.circuit.description}><CircuitDiagramPlaceholder circuit={data.circuit} /></ProjectSection>}

      <ProjectSection id="code" eyebrow="Programming concept" title="MicroPython Concept Summary" description={`This short, independently written example shows the GPIO output and timing pattern used to blink an LED. Compare pin choices and wiring with the official guide before running ${data.code.filename}.`}><CodeExample example={data.code} /></ProjectSection>

      {data.codeExplanation && <ProjectSection id="code-explanation" eyebrow="Understand it" title="How the Code Works"><ol class="space-y-3 text-slate-700">{data.codeExplanation.map((item) => <li class="rounded-xl border border-slate-200 bg-white p-4 leading-7">{item}</li>)}</ol></ProjectSection>}

      <ProjectSection id="troubleshooting" eyebrow="Problem solving" title="Common Beginner Mistakes"><Troubleshooting items={data.troubleshooting} /></ProjectSection>
      <ProjectSection id="faq" eyebrow="Common questions" title="Frequently Asked Questions"><FAQ items={data.faq} /></ProjectSection>
      {data.relatedProjects.length > 0 && <ProjectSection id="related" eyebrow="Keep building" title="Related Projects"><RelatedProjects projects={data.relatedProjects} /></ProjectSection>}

      <ProjectCompletionCTA previousProject={previousProject} nextProject={nextProject} nextPlannedProject={data.nextPlannedProject} />
      <AffiliateDisclosure />
    </div>
  </article>
</PageLayout>
