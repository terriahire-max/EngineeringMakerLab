---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import FeaturedProduct from '../components/FeaturedProduct.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TutorialCard from '../components/TutorialCard.astro';
import { productById } from '../data/products';
import Button from '../components/design-system/Button.astro';
import Icon from '../components/design-system/Icon.astro';
import DifficultyBadge from '../components/DifficultyBadge.astro';
import RecommendedFor from '../components/RecommendedFor.astro';
import WhyTrust from '../components/WhyTrust.astro';
import { sortProjectsByLearningPath, sortTutorialsByLearningPath } from '../utils/content';

const projectEntries = await getCollection('projects');
const tutorialEntries = await getCollection('tutorials');
const learningProjects = sortProjectsByLearningPath(projectEntries);
const learningTutorials = sortTutorialsByLearningPath(tutorialEntries);
const starterKit = productById.get('sunfounder-raspberry-pi-pico-ultimate-starter-kit');

if (!starterKit) throw new Error('Start Here references a missing starter kit.');

const pageTitle = 'Start Here | Engineering Maker Lab';
const pageDescription = 'A simple beginner path from choosing one electronics kit to completing five practical projects.';
const beginnerAudiences = ['Middle School', 'High School', 'Adult Beginners', 'Homeschool'] as const;
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-700">Start Here</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-900 sm:text-5xl">Your first five electronics builds</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">You do not need to plan an entire workshop. Start with one capable kit, complete five projects in order, and use the tutorials whenever a new idea appears.</p>
    </div>

    <div class="mx-auto mt-10 max-w-4xl"><RecommendedFor audiences={beginnerAudiences} compact={true} /></div>

    <section aria-labelledby="path-overview-title" class="surface-card mt-10 p-6 sm:p-8">
      <p class="eyebrow">Five-project progression</p>
      <h2 id="path-overview-title" class="heading-section mt-3">One kit, one clear path</h2>
      <ol class="mt-6 grid gap-3 md:grid-cols-5">
        {learningProjects.map((project, index) => (
          <li class="rounded-[var(--radius-surface)] border border-slate-200 bg-slate-50 p-4">
            <span class="text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">Stage {index + 1}</span>
            <p class="mt-2 font-bold text-slate-950">{project.data.title}</p>
            <div class="mt-3"><DifficultyBadge level={project.data.difficulty} /></div>
          </li>
        ))}
      </ol>
    </section>

    <ol class="mt-14 space-y-10">
      <li>
        <div class="mb-6 flex items-center gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-700 text-lg font-black text-white">1</span>
          <div><p class="text-sm font-bold uppercase tracking-[0.15em] text-blue-700">First</p><h2 class="text-3xl font-bold text-slate-900">Buy one recommended kit</h2></div>
        </div>
        <FeaturedProduct product={starterKit} />
        <div class="mt-6"><AffiliateDisclosure /></div>
      </li>

      <li class="flex justify-center text-blue-300" aria-hidden="true"><Icon name="arrow-right" size={36} class="rotate-90" /></li>

      <li>
        <div class="mb-6 flex items-center gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-700 text-lg font-black text-white">2</span>
          <div><p class="text-sm font-bold uppercase tracking-[0.15em] text-blue-700">Then</p><h2 class="text-3xl font-bold text-slate-900">Build five beginner projects</h2></div>
        </div>
        <p class="mb-7 max-w-3xl leading-7 text-slate-600">Follow these in order. Each build introduces one major idea while reusing skills and components from the previous step.</p>
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {learningProjects.map((project, index) => (
            <div class="relative">
              <span class="absolute right-5 top-5 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-slate-900 text-xs font-bold text-white">{index + 1}</span>
              <ProjectCard title={project.data.title} description={project.data.description} tag={project.data.difficulty} href={`/projects/${project.id}`} />
            </div>
          ))}
        </div>
      </li>

      <li class="flex justify-center text-blue-300" aria-hidden="true"><Icon name="arrow-right" size={36} class="rotate-90" /></li>

      <li>
        <div class="mb-6 flex items-center gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-700 text-lg font-black text-white">3</span>
          <div><p class="text-sm font-bold uppercase tracking-[0.15em] text-blue-700">Next</p><h2 class="text-3xl font-bold text-slate-900">Continue learning</h2></div>
        </div>
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {learningTutorials.map((tutorial) => (
            <TutorialCard title={tutorial.data.title} description={tutorial.data.description} level={tutorial.data.level} href={`/tutorials/${tutorial.id}`} />
          ))}
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/tutorials">Browse all tutorials</Button>
          <Button href="/buying-guides" variant="secondary">Read buying guides</Button>
        </div>
      </li>
    </ol>

    <div class="mt-16"><WhyTrust /></div>
  </section>
</PageLayout>
