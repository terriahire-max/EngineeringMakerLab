---
import PageLayout from '../../layouts/PageLayout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { products } from '../../data/products';

const pageTitle = 'Products | Engineering Maker Lab';
const pageDescription = 'Browse beginner-friendly electronics products by category.';
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading
      headingLevel="h1"
      eyebrow="Product catalog"
      title="Tools and components for practical builds"
      description="Browse the complete Engineering Maker Lab product catalog. Use Collections when you want a shorter, interest-based path."
    />

    <div class="mt-10">
      <div class="mt-6">
        <ProductGrid products={products} />
      </div>
    </div>
  </section>
</PageLayout>
