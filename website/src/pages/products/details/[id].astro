---
import type { GetStaticPaths } from 'astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProductRecommendationCard from '../../../components/ProductRecommendationCard.astro';
import AffiliateDisclosure from '../../../components/AffiliateDisclosure.astro';
import Icon from '../../../components/design-system/Icon.astro';
import { products, type Product } from '../../../data/products';
import { collectionById } from '../../../data/collections';
import type { BreadcrumbItem } from '../../../utils/seo';
import Button from '../../../components/design-system/Button.astro';

export const getStaticPaths = (() => {
  const dedicatedProductIds = new Set(['sunfounder-thales-pico-starter-kit', 'sunfounder-euler-pico-ultimate-kit', 'sunfounder-kepler-pico-w-ultimate-kit']);
  return products.filter((product) => !dedicatedProductIds.has(product.id)).map((product) => ({ params: { id: product.id }, props: { product } }));
}) satisfies GetStaticPaths;
interface Props { product: Product; }
const { product } = Astro.props;
const collection = collectionById.get(product.primaryCollection);
const breadcrumbs: BreadcrumbItem[] = [{ label: 'Home', href: '/' }, { label: 'Collections', href: '/collections' }, ...(collection ? [{ label: collection.name, href: `/collections/${collection.id}` }] : []), { label: product.name }];
---

<PageLayout title={`${product.name} | Engineering Maker Lab`} description={`${product.shortDescription} Review its learning focus, possible projects, and affiliate-link availability.`} breadcrumbs={breadcrumbs}>
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mt-8 max-w-3xl"><p class="eyebrow">Product overview</p><h1 class="heading-display mt-3">{product.name}</h1><p class="mt-5 text-lg leading-8 text-slate-600">{product.shortDescription}</p></header>
    <div class="mt-10"><ProductRecommendationCard product={product} headingLevel="h2" showDetailLink={false} /></div>
    {product.documentationUrl && <div class="mt-4"><Button href={product.documentationUrl} target="_blank" rel="noopener noreferrer" variant="secondary" ariaLabel={`Open the official documentation for ${product.name} (opens in a new tab)`}>Official Documentation</Button></div>}
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <section aria-labelledby="selling-points" class="rounded-2xl border border-slate-200 p-6"><h2 id="selling-points" class="text-2xl font-black text-slate-900">Learning Value</h2><ul class="mt-4 space-y-3">{(product.sellingPoints ?? []).map((point) => <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="check" size={17} class="mt-1 shrink-0 text-blue-700" />{point}</li>)}</ul></section>
      <section aria-labelledby="project-ideas" class="rounded-2xl border border-slate-200 p-6"><h2 id="project-ideas" class="text-2xl font-black text-slate-900">Projects and Learning Possibilities</h2><ul class="mt-4 space-y-3">{(product.highlightedProjects ?? []).map((project) => <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="arrow-right" size={17} class="mt-1 shrink-0 text-blue-700" />{project}</li>)}</ul></section>
    </div>
    <div class="mt-10"><AffiliateDisclosure /></div>
  </section>
</PageLayout>
