---
import type { GetStaticPaths } from 'astro';
import PageLayout from '../../layouts/PageLayout.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getProductsByCategory, productCategories } from '../../data/products';
import type { ProductCategory } from '../../data/products';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { BreadcrumbItem } from '../../utils/seo';

export const getStaticPaths = (() =>
  productCategories.map((category) => ({
    params: { category: category.id },
    props: { category },
  }))) satisfies GetStaticPaths;

interface Props {
  category: ProductCategory;
}

const { category } = Astro.props;
const categoryProducts = getProductsByCategory(category.id);
const pageTitle = `${category.name} | Engineering Maker Lab Products`;
const pageDescription = `${category.description} Browse Engineering Maker Lab recommendations.`;
const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: category.name },
];
---

<PageLayout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />
    <div class="mt-7">
      <SectionHeading headingLevel="h1" eyebrow="Product category" title={category.name} description={category.description} />
    </div>
    <div class="mt-10">
      <ProductGrid products={categoryProducts} emptyMessage={`No reviewed ${category.name.toLowerCase()} products are listed yet.`} />
    </div>
    <div class="mt-12">
      <AffiliateDisclosure />
    </div>
  </section>
</PageLayout>
