---
import PicoProductPage from '../../components/PicoProductPage.astro';
import { productById } from '../../data/products';
const product = productById.get('sunfounder-thales-pico-starter-kit');
if (!product) throw new Error('The Thales product entry is missing.');
---
<PicoProductPage product={product} pageTitle="SunFounder Thales Raspberry Pi Pico Starter Kit | Engineering Maker Lab" pageDescription="Explore who the SunFounder Thales Pico kit is for, its 283 items, 18 projects, selected components, and beginner learning focus." />
