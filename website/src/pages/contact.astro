---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/design-system/Button.astro';
import Icon from '../components/design-system/Icon.astro';

const pageTitle = 'Contact | Engineering Maker Lab';
const pageDescription = 'Contact Engineering Maker Lab for website feedback, content corrections, partnership inquiries, and general questions.';
const contactReasons = [
  'Questions or corrections about website content',
  'Product or official-documentation link issues',
  'Affiliate or partnership inquiries',
  'Suggestions for future electronics, robotics, or maker content',
];
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-4xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <SectionHeading
      headingLevel="h1"
      eyebrow="Contact"
      title="Contact Engineering Maker Lab"
      description="Questions, corrections, partnership inquiries, or feedback about Engineering Maker Lab are welcome."
    />

    <div class="mt-10 grid gap-6 md:grid-cols-[0.9fr_1.1fr]">
      <section class="surface-card p-6 sm:p-8" aria-labelledby="contact-details">
        <h2 id="contact-details" class="text-2xl font-bold text-slate-950">Contact information</h2>
        <address class="mt-6 space-y-5 not-italic">
          <div class="flex gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="arrow-right" /></span>
            <div><p class="text-sm font-semibold text-slate-500">Email</p><a href="mailto:info@engineeringmakerlab.com" class="mt-1 block break-all rounded-md font-bold text-blue-700 hover:text-blue-900 sm:break-normal">info@engineeringmakerlab.com</a></div>
          </div>
          <div class="flex gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="home" /></span>
            <div><p class="text-sm font-semibold text-slate-500">Location</p><p class="mt-1 font-bold text-slate-900">Frisco, Texas</p></div>
          </div>
        </address>
        <p class="mt-6 border-t border-slate-200 pt-5 text-sm leading-6 text-slate-600">Messages are reviewed as availability allows.</p>
      </section>

      <section class="surface-card p-6 sm:p-8" aria-labelledby="reasons-to-contact">
        <h2 id="reasons-to-contact" class="text-2xl font-bold text-slate-950">How we can help</h2>
        <ul class="mt-5 space-y-3">
          {contactReasons.map((reason) => <li class="flex gap-3 text-sm leading-6 text-slate-700"><Icon name="check" size={17} class="mt-1 shrink-0 text-blue-700" />{reason}</li>)}
        </ul>
        <div class="mt-6 rounded-xl border border-orange-200 bg-orange-50 p-4 text-sm leading-6 text-orange-950">
          For order, shipping, warranty, returns, or product-specific support, please contact the product manufacturer or retailer directly.
        </div>
      </section>
    </div>

    <nav aria-label="Helpful pages" class="mt-8 rounded-2xl border border-slate-200 bg-white p-5 sm:flex sm:items-center sm:justify-between sm:gap-6">
      <div><h2 class="text-lg font-bold text-slate-950">Helpful pages</h2><p class="mt-1 text-sm leading-6 text-slate-600">Learn more about the site or review its policies.</p></div>
      <div class="mt-4 flex flex-col gap-3 sm:mt-0 sm:flex-row"><Button href="/about" variant="secondary">About</Button><Button href="/affiliate-disclosure" variant="secondary">Affiliate Disclosure</Button><a href="/privacy" class="self-center rounded-md text-sm font-bold text-blue-700 hover:text-blue-900">Privacy</a></div>
    </nav>
  </section>
</PageLayout>
