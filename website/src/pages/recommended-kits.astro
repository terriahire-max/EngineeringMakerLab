---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProductGrid from '../components/ProductGrid.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { getProductsByCategory } from '../data/products';

const pageTitle = 'Recommended Kits | Engineering Maker Lab';
const pageDescription = 'Curated beginner electronics starter kits and practical gear recommendations.';
const starterKits = getProductsByCategory('starter-kits');
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading
      headingLevel="h1"
      eyebrow="Recommended kits"
      title="Starter recommendations"
      description="Beginner-friendly kits selected from the central Engineering Maker Lab product catalog."
    />
    <div class="mt-8">
      <ProductGrid products={starterKits} />
    </div>
    <div class="mt-12">
      <AffiliateDisclosure />
    </div>
  </section>
</PageLayout>
