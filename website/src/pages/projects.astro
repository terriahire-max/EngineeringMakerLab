---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const pageTitle = 'Projects | Engineering Maker Lab';
const pageDescription = 'Browse complete beginner-friendly electronics projects and practical learning paths.';
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading headingLevel="h1" eyebrow="Projects" title="Build something real" description="Complete guides with parts, wiring guidance, working code, troubleshooting, and a clear next project." />
    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard title={project.data.title} description={project.data.description} tag={project.data.difficulty} href={`/projects/${project.id}`} />
      ))}
    </div>
  </section>
</PageLayout>
