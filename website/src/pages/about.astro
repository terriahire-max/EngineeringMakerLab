---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/design-system/Button.astro';
import Icon from '../components/design-system/Icon.astro';

const pageTitle = 'About | Engineering Maker Lab';
const pageDescription = 'Learn how Engineering Maker Lab helps beginners, students, teachers, and makers discover electronics, robotics, programming products, and official learning resources.';
const audiences = ['Beginners building confidence with electronics', 'Students, teachers, and homeschool families', 'Makers exploring programming, robotics, and physical computing'];
const selectionFactors = ['Relevant to electronics, programming, robotics, or maker learning', 'Supported by official manufacturer documentation', 'Suitable for practical projects with a clear platform and audience'];
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <div class="max-w-4xl"><SectionHeading headingLevel="h1" eyebrow="About" title="About Engineering Maker Lab" description="A clear starting point for discovering electronics, programming, robotics, and physical-computing products with official learning resources." /></div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <section class="surface-card p-6 sm:p-8" aria-labelledby="purpose"><span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="cpu" /></span><h2 id="purpose" class="mt-5 text-2xl font-bold text-slate-950">Our purpose</h2><p class="mt-3 leading-7 text-slate-600">Engineering Maker Lab organizes approachable products and learning paths so visitors can understand what a kit or component supports before following its official guide.</p></section>
      <section class="surface-card p-6 sm:p-8" aria-labelledby="audience"><span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="users" /></span><h2 id="audience" class="mt-5 text-2xl font-bold text-slate-950">Who the site is for</h2><ul class="mt-4 space-y-3">{audiences.map((item) => <li class="flex gap-3 text-sm leading-6 text-slate-700"><Icon name="check" size={17} class="mt-1 shrink-0 text-blue-700" />{item}</li>)}</ul></section>
    </div>

    <section class="mt-6 surface-card p-6 sm:p-8" aria-labelledby="selection"><div class="max-w-3xl"><p class="eyebrow">Curation</p><h2 id="selection" class="mt-3 text-2xl font-bold text-slate-950">How products are selected</h2><p class="mt-3 leading-7 text-slate-600">Products are included because they fit the site's educational focus and provide useful official learning resources. Inclusion does not imply personal testing or a universal recommendation.</p></div><ul class="mt-5 grid gap-3 md:grid-cols-3">{selectionFactors.map((item) => <li class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm font-medium leading-6 text-slate-700">{item}</li>)}</ul></section>

    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      <section class="surface-card p-6 sm:p-8" aria-labelledby="documentation"><span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="book-open" /></span><h2 id="documentation" class="mt-5 text-2xl font-bold text-slate-950">Official documentation</h2><p class="mt-3 leading-7 text-slate-600">Product pages link to manufacturer documentation, which remains the primary source for setup, wiring, code, specifications, and troubleshooting. Engineering Maker Lab provides context and discovery without replacing those guides.</p></section>
      <section class="surface-card p-6 sm:p-8" aria-labelledby="affiliate-transparency"><span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name="shield-check" /></span><h2 id="affiliate-transparency" class="mt-5 text-2xl font-bold text-slate-950">Affiliate transparency</h2><p class="mt-3 leading-7 text-slate-600">Some product links are affiliate links. Engineering Maker Lab may earn a commission from a qualifying purchase at no additional cost to the visitor.</p><a href="/affiliate-disclosure" class="mt-4 inline-flex rounded-md text-sm font-bold text-blue-700 hover:text-blue-900">Read the affiliate disclosure <Icon name="arrow-right" class="ml-2" /></a></section>
    </div>

    <section class="mt-6 rounded-[var(--radius-card)] bg-slate-950 p-6 text-white sm:p-8" aria-labelledby="location-contact"><h2 id="location-contact" class="text-2xl font-bold text-white">Location and contact</h2><address class="mt-4 not-italic"><p class="text-sm leading-6 text-slate-300">Based in <strong class="text-white">Frisco, Texas</strong></p><a href="mailto:info@engineeringmakerlab.com" class="mt-2 block break-all rounded-md font-bold text-blue-300 hover:text-white sm:break-normal">info@engineeringmakerlab.com</a></address><div class="mt-6"><Button href="/contact" variant="inverse">Contact Engineering Maker Lab</Button></div></section>
  </section>
</PageLayout>
