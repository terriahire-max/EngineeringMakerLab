---
import type { GetStaticPaths } from 'astro';
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductRecommendationCard from '../../components/ProductRecommendationCard.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import Icon from '../../components/design-system/Icon.astro';
import PicoCollectionPage from '../../components/PicoCollectionPage.astro';
import { productCollections, type ProductCollection } from '../../data/collections';
import { getProductsByCollection } from '../../data/products';
import type { BreadcrumbItem } from '../../utils/seo';

export const getStaticPaths = (() => productCollections.map((collection) => ({ params: { slug: collection.id }, props: { collection } }))) satisfies GetStaticPaths;
interface Props { collection: ProductCollection; }
const { collection } = Astro.props;
const recommendedProducts = getProductsByCollection(collection.id);
const breadcrumbs: BreadcrumbItem[] = [{ label: 'Home', href: '/' }, { label: 'Collections', href: '/collections' }, { label: collection.name }];
---

<PageLayout title={collection.seoTitle} description={collection.seoDescription} breadcrumbs={breadcrumbs}>
  {collection.id === 'raspberry-pi-pico' ? <PicoCollectionPage products={recommendedProducts} breadcrumbs={breadcrumbs} /> : <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mt-8 max-w-3xl">
      <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-100 text-blue-700" aria-hidden="true"><Icon name={collection.icon} size={26} /></span>
      <h1 class="heading-display mt-5">{collection.name} Kits</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">{collection.description}</p>
    </header>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <section aria-labelledby="who-for" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="who-for" class="text-2xl font-black text-slate-900">Who It Is For</h2><ul class="mt-4 space-y-3">{collection.audience.map((item) => <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="users" size={17} class="mt-1 shrink-0 text-blue-700" />{item}</li>)}</ul></section>
      <section aria-labelledby="skills" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="skills" class="text-2xl font-black text-slate-900">Skills You Can Learn</h2><ul class="mt-4 space-y-3">{collection.skills.map((item) => <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="check" size={17} class="mt-1 shrink-0 text-blue-700" />{item}</li>)}</ul></section>
    </div>

    <section aria-labelledby="recommended-products" class="mt-14">
      <p class="eyebrow">Product recommendations</p><h2 id="recommended-products" class="heading-section mt-3">Recommended {collection.name} Products</h2>
      <div class="mt-8 grid gap-6 lg:grid-cols-3">{recommendedProducts.map((product) => <ProductRecommendationCard product={product} />)}</div>
    </section>

    <section aria-labelledby="possible-builds" class="mt-14 rounded-[var(--radius-card)] bg-slate-950 p-7 text-white sm:p-9">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-300">Learning possibilities</p><h2 id="possible-builds" class="mt-3 text-3xl font-black text-white">Projects and Possible Builds</h2>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{collection.builds.map((build) => <li class="rounded-2xl border border-white/10 bg-white/5 p-4 font-semibold text-slate-100">{build}</li>)}</ul>
    </section>
    <div class="mt-10"><AffiliateDisclosure /></div>
  </section>}
</PageLayout>
