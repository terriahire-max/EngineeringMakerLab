---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TutorialCard from '../components/TutorialCard.astro';

const tutorials = (await getCollection('tutorials')).sort((a, b) => a.data.order - b.data.order);
const pageTitle = 'Tutorials | Engineering Maker Lab';
const pageDescription = 'Beginner tutorials that explain practical electronics concepts clearly.';
---

<PageLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <SectionHeading headingLevel="h1" eyebrow="Tutorials" title="Learn the ideas behind each build" description="Short, focused lessons that make breadboards, GPIO, PWM, servos, and project power easier to understand." />
    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {tutorials.map((tutorial) => (
        <TutorialCard title={tutorial.data.title} description={tutorial.data.description} level={tutorial.data.level} href={`/tutorials/${tutorial.id}`} />
      ))}
    </div>
  </section>
</PageLayout>
