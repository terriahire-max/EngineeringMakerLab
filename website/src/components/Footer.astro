---
import { footerDisclosure } from '../data/site';
import Logo from './design-system/Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-950 text-slate-200">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.25fr_0.75fr_0.75fr] lg:px-8">
    <div>
      <a href="/" aria-label="Engineering Maker Lab home" class="inline-flex rounded-xl"><Logo theme="dark" /></a>
      <p class="mt-3 max-w-xl text-sm leading-6 text-slate-300">
        Practical electronics learning for beginners, with curated starter projects, tutorials,
        and trustworthy gear recommendations.
      </p>
      <address class="mt-3 text-sm not-italic text-slate-400"><a href="mailto:info@engineeringmakerlab.com" class="rounded-md hover:text-white">info@engineeringmakerlab.com</a><span class="mx-2" aria-hidden="true">·</span><span>Frisco, Texas</span></address>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Explore</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/collections" class="hover:text-white">Collections</a></li>
        <li><a href="/products" class="hover:text-white">Products</a></li>
        <li><a href="/projects" class="hover:text-white">Projects</a></li>
        <li><a href="/tutorials" class="hover:text-white">Tutorials</a></li>
        <li><a href="/start-here" class="hover:text-white">Start Here</a></li>
        <li><a href="/buying-guides" class="hover:text-white">Buying Guides</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Policies</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about" class="hover:text-white">About</a></li>
        <li><a href="/affiliate-disclosure" class="hover:text-white">Affiliate Disclosure</a></li>
        <li><a href="/privacy" class="hover:text-white">Privacy Policy</a></li>
        <li><a href="/contact" class="hover:text-white">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-5 text-sm text-slate-400 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <p>&copy; {currentYear} Engineering Maker Lab. All rights reserved.</p>
      <p class="max-w-2xl text-xs leading-6">
        {footerDisclosure}
      </p>
    </div>
  </div>
</footer>
