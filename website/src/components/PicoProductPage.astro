---
import type { Product } from '../data/products';
import { getProductCtaLabel, isActiveAffiliateLink } from '../data/products';
import { getProjectHref, projectResourceById } from '../data/projectResources';
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import AffiliateDisclosure from './AffiliateDisclosure.astro';
import BuyButtons from './BuyButtons.astro';
import Button from './design-system/Button.astro';
import Icon from './design-system/Icon.astro';
import type { BreadcrumbItem } from '../utils/seo';

interface Props { product: Product; pageTitle: string; pageDescription: string; }
const { product, pageTitle, pageDescription } = Astro.props;
const profile = product.picoKitProfile;
if (!profile) throw new Error(`Pico product data is missing for "${product.id}".`);
const activeAffiliate = isActiveAffiliateLink(product.affiliateLinks.sunfounder);
const projects = profile.projectIds.map((projectId) => {
  const project = projectResourceById.get(projectId);
  if (!project) throw new Error(`Project resource data is missing for "${projectId}".`);
  return project;
});
if (import.meta.env.DEV && !activeAffiliate) console.warn(`[affiliate-config] ${product.id} requires a verified SunFounder affiliate URL.`);
const breadcrumbs: BreadcrumbItem[] = [{ label: 'Home', href: '/' }, { label: 'Collections', href: '/collections' }, { label: 'Raspberry Pi Pico', href: '/collections/raspberry-pi-pico' }, { label: product.name }];
---

<PageLayout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mt-8 rounded-[var(--radius-card)] bg-slate-950 p-7 text-white sm:p-9">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-300">{product.brand} · {product.platform} · {profile.verifiedProductInfo}</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">{product.name}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{profile.explanation}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        {activeAffiliate && <div class="w-full sm:w-auto"><BuyButtons links={product.affiliateLinks} preferredVendor="SunFounder" buttonLabel={getProductCtaLabel(product)} activeOnly={true} /></div>}
        <Button href={profile.officialDocumentationUrl} target="_blank" rel="noopener noreferrer" variant="inverse" class="w-full sm:w-auto" ariaLabel={`Open the official ${profile.comparisonLabel} documentation (opens in a new tab)`}>View Official Documentation</Button>
      </div>
      {activeAffiliate && <p class="mt-4 text-xs leading-5 text-slate-300">Affiliate link: Engineering Maker Lab may earn a commission at no additional cost to you.</p>}
    </header>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <section aria-labelledby="who-for" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="who-for" class="text-2xl font-black text-slate-900">Who It Is For</h2><p class="mt-4 leading-7 text-slate-600">{profile.bestFor}</p></section>
      <section aria-labelledby="what-teaches" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="what-teaches" class="text-2xl font-black text-slate-900">What It Teaches</h2><p class="mt-4 leading-7 text-slate-600">{profile.learningFocus}</p></section>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <section aria-labelledby="important-components" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="important-components" class="text-2xl font-black text-slate-900">Selected Important Components</h2><ul class="mt-5 space-y-3">{(profile.selectedComponents ?? product.includedComponents).map((item) => <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="check" size={17} class="mt-1 shrink-0 text-blue-700" />{item}</li>)}</ul></section>
      <section aria-labelledby="project-examples" class="rounded-2xl border border-slate-200 bg-white p-6"><h2 id="project-examples" class="text-2xl font-black text-slate-900">Interesting Project Examples</h2><ul class="mt-5 space-y-3">{projects.map((project) => {
        const href = getProjectHref(project);
        const external = project.status !== 'published' && Boolean(project.officialGuideUrl);
        return <li class="flex gap-2 text-sm leading-6 text-slate-700"><Icon name="arrow-right" size={17} class="mt-1 shrink-0 text-blue-700" /><span>{href ? <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined} class="font-semibold text-blue-700 underline decoration-blue-200 underline-offset-4 hover:text-blue-900 visited:text-purple-700">{project.title}{external && ` — ${project.officialGuideLabel ?? 'Official Guide'}`}</a> : <>{project.title} <span class="ml-1 text-xs font-bold uppercase tracking-wide text-slate-500">Planned</span></>}</span></li>;
      })}</ul></section>
    </div>

    <aside class="mt-6 rounded-2xl border border-blue-100 bg-blue-50 p-5" aria-labelledby="why-included"><h2 id="why-included" class="text-lg font-bold text-slate-900">Why it is included</h2><p class="mt-2 text-sm leading-6 text-slate-700">Engineering Maker Lab includes products that have official documentation and support practical electronics, robotics, or programming learning.</p></aside>

    <div class="mt-10"><AffiliateDisclosure /></div>
  </section>
</PageLayout>
