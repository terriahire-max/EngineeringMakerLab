---
import BuyButtons from './BuyButtons.astro';
import Badge from './design-system/Badge.astro';
import Icon from './design-system/Icon.astro';
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<aside id="recommended-kit" aria-labelledby="recommended-kit-title" class="relative scroll-mt-28 overflow-hidden rounded-[var(--radius-card)] bg-slate-950 px-6 py-8 text-white shadow-[var(--shadow-elevated)] sm:px-8 lg:px-10 lg:py-10">
  <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-orange-500/20 blur-3xl" aria-hidden="true"></div>
  <div class="relative grid gap-8 lg:grid-cols-[1fr_0.65fr] lg:items-center">
    <div>
      <p class="inline-flex rounded-full bg-orange-500 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-white">Recommended Kit for This Project</p>
      <h2 id="recommended-kit-title" class="mt-4 text-3xl font-black tracking-tight sm:text-4xl">{product.name}</h2>
      <p class="mt-2 text-sm font-semibold text-blue-300">{product.brand}</p>
      <div class="mt-4 flex flex-wrap gap-2"><Badge>{product.platform}</Badge><Badge>{product.level}</Badge></div>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-300">{product.shortDescription}</p>
      <div class="mt-5">
        <p class="text-lg font-bold text-white">Need the parts?</p>
        <p class="mt-1 text-sm leading-6 text-slate-300">Get the recommended kit before starting. It includes the main components used for this beginner project.</p>
        <ul class="mt-3 grid gap-x-4 gap-y-2 text-sm text-slate-200 sm:grid-cols-2">
          {product.includedComponents.map((component) => (
            <li class="flex items-start gap-2"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-300" /> <span>{component}</span></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
      <p class="text-sm font-semibold text-white">Start with the recommended kit</p>
      <div class="mt-5"><BuyButtons links={product.affiliateLinks} preferredVendor="SunFounder" buttonLabel="Get the Recommended Kit" activeOnly={true} stacked={true} /></div>
      <p class="mt-4 text-xs leading-5 text-slate-300">Affiliate link: Engineering Maker Lab may earn a commission at no additional cost to you.</p>
    </div>
  </div>
</aside>
