---
import BuyButtons from './BuyButtons.astro';
import ProductBadge from './ProductBadge.astro';
import Icon from './design-system/Icon.astro';
import { hasActiveAffiliateLinks, type Product } from '../data/products';
import Button from './design-system/Button.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const hasRetailers = hasActiveAffiliateLinks(product.affiliateLinks);
---

<aside id="recommended-kit" aria-labelledby="recommended-kit-title" class="relative scroll-mt-28 overflow-hidden rounded-[var(--radius-card)] bg-slate-950 px-6 py-8 text-white shadow-[var(--shadow-elevated)] sm:px-8 lg:px-10 lg:py-10">
  <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-orange-500/20 blur-3xl" aria-hidden="true"></div>
  <div class="relative grid gap-8 lg:grid-cols-[0.55fr_1fr_0.8fr] lg:items-center">
    <img src={product.image.src} alt={product.image.alt} class="aspect-[4/3] w-full rounded-2xl bg-white object-cover" width="800" height="600" loading="lazy" decoding="async" />
    <div>
      <p class="inline-flex rounded-full bg-orange-500 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-white">Recommended Kit</p>
      <h2 id="recommended-kit-title" class="mt-4 text-3xl font-black tracking-tight sm:text-4xl">{product.name}</h2>
      <p class="mt-2 text-sm font-semibold text-blue-300">{product.brand}</p>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-300">{product.shortDescription}</p>
      <div class="mt-5">
        <p class="text-xs font-extrabold uppercase tracking-[0.14em] text-slate-400">Included components</p>
        <ul class="mt-3 grid gap-x-4 gap-y-2 text-sm text-slate-200 sm:grid-cols-2">
          {product.includedComponents.slice(0, 8).map((component) => (
            <li class="flex items-start gap-2"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-300" /> <span>{component}</span></li>
          ))}
        </ul>
      </div>
      <div class="mt-5">
        <ProductBadge level={product.level} featured={product.featured} />
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
      {hasRetailers ? (
        <>
          <p class="text-sm font-semibold text-white">Compare retailers</p>
          <p class="mt-1 text-xs leading-5 text-slate-400">Use the retailer that best fits your location and budget.</p>
          <div class="mt-5"><BuyButtons links={product.affiliateLinks} stacked={true} /></div>
          <a href="/affiliate-disclosure" class="mt-4 block text-center text-xs font-medium text-slate-400 underline decoration-slate-600 underline-offset-4 hover:text-white">Read our affiliate disclosure</a>
        </>
      ) : (
        <>
          <p class="text-sm font-semibold text-white">Why this kit fits</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Its Pico board, breadboard, sensors, and input components support the complete beginner project path.</p>
          <div class="mt-5"><Button href="/products/starter-kits" variant="inverse" class="w-full">Compare starter kits</Button></div>
        </>
      )}
    </div>
  </div>
</aside>
