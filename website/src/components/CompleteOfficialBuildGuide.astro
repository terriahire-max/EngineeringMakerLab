---
import type { ProjectResource } from '../data/projectResources';
import Button from './design-system/Button.astro';

interface Props { resource: ProjectResource; }
const { resource } = Astro.props;
---

{resource.resourceVerified && resource.officialGuideUrl ? (
  <div class="rounded-2xl border border-blue-200 bg-blue-50 p-6">
    <p class="font-bold text-slate-900">{resource.officialGuideTitle}</p>
    <p class="mt-2 leading-7 text-slate-700">Already have the recommended equipment? The verified SunFounder lesson provides the exact wiring, schematic, code, and step-by-step build instructions.</p>
    {resource.officialGuideDescription && <p class="mt-2 text-sm leading-6 text-slate-600">{resource.officialGuideDescription}</p>}
    <div class="mt-5">
      <Button href={resource.officialGuideUrl} target="_blank" rel="noopener noreferrer" variant="secondary" ariaLabel={`Open Official SunFounder Guide for ${resource.title} (opens in a new tab)`}>Open Official SunFounder Guide</Button>
    </div>
  </div>
) : (
  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 leading-7 text-slate-700">An exact official build guide for this project is still being verified.</div>
)}
