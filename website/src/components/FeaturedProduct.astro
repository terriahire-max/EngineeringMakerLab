---
import BuyButtons from './BuyButtons.astro';
import ProductBadge from './ProductBadge.astro';
import { hasActiveAffiliateLinks, type Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const hasRetailers = hasActiveAffiliateLinks(product.affiliateLinks);
---

<article class="overflow-hidden rounded-[var(--radius-card)] bg-slate-950 text-white shadow-[var(--shadow-elevated)]">
  <div class="grid lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
    <div class="h-full min-h-72 bg-white">
      <img src={product.image.src} alt={product.image.alt} class="h-full w-full object-cover" width="800" height="600" loading="lazy" decoding="async" />
    </div>
    <div class="p-7 sm:p-9 lg:p-12">
      <div class="flex flex-wrap items-center gap-3">
        <ProductBadge level={product.level} featured={product.featured} />
        <span class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">{product.brand}</span>
      </div>
      <h2 class="mt-5 text-3xl font-black tracking-tight sm:text-4xl">{product.name}</h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{product.shortDescription}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {product.tags.map((tag) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300">{tag}</span>
        ))}
      </div>
      {hasRetailers && <div class="mt-7 max-w-xl">
        <BuyButtons links={product.affiliateLinks} />
      </div>}
      {hasRetailers && <a href="/affiliate-disclosure" class="mt-4 inline-block text-xs text-slate-400 underline decoration-slate-600 underline-offset-4 hover:text-white">Affiliate disclosure</a>}
    </div>
  </div>
</article>
