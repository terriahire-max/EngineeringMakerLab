---
import type { CollectionEntry } from 'astro:content';
import Icon from './design-system/Icon.astro';

type ProjectAnswer = CollectionEntry<'projects'>['data']['faq'][number];

interface Props {
  items: ProjectAnswer[];
  openFirst?: boolean;
}

const { items, openFirst = false } = Astro.props;
---

<div class="space-y-3">
  {items.map((item, index) => (
    <details class="group surface-card rounded-[var(--radius-surface)] px-5 py-4" open={openFirst && index === 0}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-900">
        <span>{item.question}</span>
        <Icon name="plus" class="text-blue-700 transition group-open:rotate-45" />
      </summary>
      <p class="mt-3 max-w-4xl pr-8 text-sm leading-6 text-slate-600">{item.answer}</p>
    </details>
  ))}
</div>
