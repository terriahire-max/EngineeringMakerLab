---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  kitName: string;
}

const { projects, kitName } = Astro.props;
---

{projects.length > 0 && (
  <section aria-labelledby="kit-projects-title" class="border-t border-slate-200 pt-12">
    <div class="max-w-3xl">
      <p class="eyebrow">Reuse your kit</p>
      <h2 id="kit-projects-title" class="heading-section mt-3">More projects you can build with this kit</h2>
      <p class="mt-3 leading-7 text-slate-600">Keep using the {kitName} instead of starting with a new parts list.</p>
    </div>
    <div class="mt-7 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.slice(0, 6).map((project) => (
        <ProjectCard title={project.data.title} description={project.data.description} tag={project.data.difficulty} href={`/projects/${project.id}`} />
      ))}
    </div>
  </section>
)}
