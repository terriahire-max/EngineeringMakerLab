---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<section id={id} class="scroll-mt-24 border-t border-slate-200 pt-12">
  <div class="max-w-3xl">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">{eyebrow}</p>}
    <h2 class:list={["text-3xl font-bold tracking-tight text-slate-900", { "mt-2": eyebrow }]}>{title}</h2>
    {description && <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>}
  </div>
  <div class="mt-7">
    <slot />
  </div>
</section>
