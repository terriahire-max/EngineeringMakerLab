---
import type { BreadcrumbItem } from '../utils/seo';

interface Props { items: BreadcrumbItem[]; }
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-slate-500">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="contents">
        {index > 0 && <span aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href} class="rounded-md hover:text-blue-700">{item.label}</a>
        ) : (
          <span class="font-medium text-slate-700" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
