---
import { isActiveAffiliateLink, type AffiliateLinks } from '../data/products';
import Button from './design-system/Button.astro';

interface Props {
  links: AffiliateLinks;
  stacked?: boolean;
  preferredVendor?: string;
  buttonLabel?: string;
  activeOnly?: boolean;
}

const { links, stacked = false, preferredVendor, buttonLabel } = Astro.props;
const allVendors = [
  { name: 'Amazon', url: links.amazon, variant: 'conversion' as const },
  { name: 'SunFounder', url: links.sunfounder, variant: 'primary' as const },
  ...Object.entries(links.additionalVendors ?? {}).map(([name, url]) => ({
    name,
    url,
    variant: 'secondary' as const,
  })),
];
const preferred = preferredVendor ? allVendors.filter((vendor) => vendor.name === preferredVendor) : allVendors;
const vendors = preferred.filter((vendor): vendor is (typeof allVendors)[number] & { url: string } => isActiveAffiliateLink(vendor.url));
---

{vendors.length > 0 && <div class:list={['grid gap-3', stacked ? 'grid-cols-1' : 'sm:grid-cols-2']}>
  {vendors.map((vendor) => {
    return <Button
      href={vendor.url}
      rel="sponsored nofollow noopener noreferrer"
      target="_blank"
      ariaLabel={`${vendor.name === 'Amazon' ? 'Buy on' : 'Buy from'} ${vendor.name} (opens in a new tab)`}
      variant={vendor.variant}
      class="w-full"
    >
      {buttonLabel ?? (vendor.name === 'Amazon' ? 'Buy on Amazon' : `Buy from ${vendor.name}`)}
    </Button>
  })}
</div>}
