---
interface Props { src: string; alt: string; width: number; height: number; caption: string; priority?: boolean; }
const { src, alt, width, height, caption, priority = false } = Astro.props;
---
<figure>
  <img src={src} alt={alt} width={width} height={height} class="h-auto w-full rounded-3xl border border-slate-200 bg-white object-contain shadow-sm" loading={priority ? 'eager' : 'lazy'} fetchpriority={priority ? 'high' : undefined} decoding="async" />
  <figcaption class="mt-3 text-center text-sm text-slate-500">{caption}</figcaption>
</figure>
