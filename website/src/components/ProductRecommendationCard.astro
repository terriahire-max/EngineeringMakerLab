---
import type { Product } from '../data/products';
import { isActiveAffiliateLink } from '../data/products';
import BuyButtons from './BuyButtons.astro';
import DifficultyBadge from './DifficultyBadge.astro';
import Button from './design-system/Button.astro';
import Icon from './design-system/Icon.astro';

interface Props { product: Product; headingLevel?: 'h2' | 'h3'; showDetailLink?: boolean; }
const { product, headingLevel = 'h3', showDetailLink = true } = Astro.props;
const HeadingTag = headingLevel;
const picoProductIds = new Set(['sunfounder-thales-pico-starter-kit', 'sunfounder-euler-pico-ultimate-kit', 'sunfounder-kepler-pico-w-ultimate-kit']);
const detailUrl = picoProductIds.has(product.id) ? `/products/${product.id}` : `/products/details/${product.id}`;
const hasSunFounderLink = isActiveAffiliateLink(product.affiliateLinks.sunfounder);
---

<article class="surface-card flex h-full flex-col p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">{product.brand} · {product.platform}</p>
    <DifficultyBadge level={product.level} />
  </div>
  <HeadingTag class="mt-4 text-xl font-black leading-7 text-slate-900">{product.name}</HeadingTag>
  <p class="mt-3 text-sm leading-6 text-slate-600">{product.shortDescription}</p>
  {product.sellingPoints && <ul class="mt-4 space-y-2">{product.sellingPoints.slice(0, 2).map((point) => <li class="flex gap-2 text-sm text-slate-700"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-700" />{point}</li>)}</ul>}
  <div class="mt-auto pt-5">
    {hasSunFounderLink ? <><BuyButtons links={product.affiliateLinks} preferredVendor="SunFounder" buttonLabel="Get the Kit" activeOnly={true} stacked={true} /><p class="mt-3 text-xs leading-5 text-slate-500">Affiliate link: Engineering Maker Lab may earn a commission at no additional cost to you.</p></> : <p class="rounded-xl bg-slate-100 p-3 text-center text-sm font-semibold text-slate-600">Product link being prepared</p>}
    {showDetailLink && <div class="mt-3"><Button href={detailUrl} variant="secondary" class="w-full" ariaLabel={`Explore ${product.name}`}>Explore product <Icon name="arrow-right" /></Button></div>}
  </div>
</article>
