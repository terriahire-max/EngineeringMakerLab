---
import type { Product } from '../data/products';
import { getProductCtaLabel, getProductPath, isActiveAffiliateLink } from '../data/products';
import BuyButtons from './BuyButtons.astro';
import DifficultyBadge from './DifficultyBadge.astro';
import Icon from './design-system/Icon.astro';

interface Props { product: Product; headingLevel?: 'h2' | 'h3'; showDetailLink?: boolean; }
const { product, headingLevel = 'h3', showDetailLink = true } = Astro.props;
const HeadingTag = headingLevel;
const detailUrl = getProductPath(product);
const hasSunFounderLink = isActiveAffiliateLink(product.affiliateLinks.sunfounder);
---

<article class="surface-card flex h-full flex-col p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">{product.brand} · {product.platform}</p>
    <DifficultyBadge level={product.level} />
  </div>
  <HeadingTag class="mt-4 text-xl font-black leading-7 text-slate-900"><a href={detailUrl} class="rounded-md hover:text-blue-700">{product.name}</a></HeadingTag>
  <p class="mt-3 text-sm leading-6 text-slate-600">{product.shortDescription}</p>
  {product.sellingPoints && <ul class="mt-4 space-y-2">{product.sellingPoints.slice(0, 2).map((point) => <li class="flex gap-2 text-sm text-slate-700"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-700" />{point}</li>)}</ul>}
  <div class="mt-auto pt-5">
    {hasSunFounderLink ? <><BuyButtons links={product.affiliateLinks} preferredVendor="SunFounder" buttonLabel={getProductCtaLabel(product)} activeOnly={true} stacked={true} /><p class="mt-3 text-xs leading-5 text-slate-500">Affiliate link: Engineering Maker Lab may earn a commission at no additional cost to you.</p></> : <p class="rounded-xl bg-slate-100 p-3 text-center text-sm font-semibold text-slate-600">Affiliate link being configured</p>}
    {showDetailLink && <a href={detailUrl} class="mt-4 inline-flex rounded-md text-sm font-bold text-blue-700 hover:text-blue-900">View product details <Icon name="arrow-right" class="ml-2" /></a>}
    {product.documentationUrl && <a href={product.documentationUrl} target="_blank" rel="noopener noreferrer" class="mt-3 block rounded-md text-sm font-semibold text-blue-700 hover:text-blue-900" aria-label={`View official documentation for ${product.name} (opens in a new tab)`}>View official documentation</a>}
  </div>
</article>
