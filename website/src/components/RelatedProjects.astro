---
import type { CollectionEntry } from 'astro:content';
import Icon from './design-system/Icon.astro';

type RelatedProject = CollectionEntry<'projects'>['data']['relatedProjects'][number];

interface Props {
  projects: RelatedProject[];
}

const { projects } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-3">
  {projects.map((project) => (
    <article class="surface-card surface-card--interactive flex flex-col p-6">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-blue-700">{project.difficulty}</p>
      <h3 class="mt-3 text-xl font-bold text-slate-900">{project.title}</h3>
      <p class="mt-3 flex-1 text-sm leading-6 text-slate-600">{project.description}</p>
      <a href={project.href} class="text-link mt-5">
        Explore project <Icon name="arrow-right" />
      </a>
    </article>
  ))}
</div>
