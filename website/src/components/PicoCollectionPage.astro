---
import type { Product } from '../data/products';
import { isActiveAffiliateLink } from '../data/products';
import Breadcrumbs from './Breadcrumbs.astro';
import AffiliateDisclosure from './AffiliateDisclosure.astro';
import BuyButtons from './BuyButtons.astro';
import Button from './design-system/Button.astro';
import Icon from './design-system/Icon.astro';
import type { BreadcrumbItem } from '../utils/seo';

interface Props { products: Product[]; breadcrumbs: BreadcrumbItem[]; }
const { products, breadcrumbs } = Astro.props;
const kits = products.map((product) => {
  if (!product.picoKitProfile) throw new Error(`Pico comparison data is missing for "${product.id}".`);
  return { product, profile: product.picoKitProfile, active: isActiveAffiliateLink(product.affiliateLinks.sunfounder) };
});
if (import.meta.env.DEV) kits.filter((kit) => !kit.active).forEach((kit) => console.warn(`[affiliate-config] ${kit.product.id} requires a verified SunFounder affiliate URL.`));
---

<section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
  <Breadcrumbs items={breadcrumbs} />
  <header class="mt-8 max-w-4xl">
    <p class="eyebrow">Compare three beginner kits</p>
    <h1 class="heading-display mt-3">Raspberry Pi Pico Kits</h1>
    <p class="mt-5 text-lg leading-8 text-slate-600">Choose a beginner-friendly Pico kit based on how many components, projects, and wireless features you want to explore.</p>
    <nav aria-label="Choose a Pico kit" class="mt-7 grid gap-3 sm:grid-cols-3">
      <a href="#thales" class="rounded-2xl border border-slate-200 bg-white p-4 font-bold text-slate-900 transition hover:border-blue-400 hover:text-blue-700">Start simple <span class="mt-1 block text-xs font-medium text-slate-500">Thales</span></a>
      <a href="#euler" class="rounded-2xl border border-slate-200 bg-white p-4 font-bold text-slate-900 transition hover:border-blue-400 hover:text-blue-700">Build more projects <span class="mt-1 block text-xs font-medium text-slate-500">Euler</span></a>
      <a href="#kepler" class="rounded-2xl border border-slate-200 bg-white p-4 font-bold text-slate-900 transition hover:border-blue-400 hover:text-blue-700">Explore Wi-Fi and IoT <span class="mt-1 block text-xs font-medium text-slate-500">Kepler</span></a>
    </nav>
  </header>

  <section aria-labelledby="quick-comparison" class="mt-14">
    <p class="eyebrow">At a glance</p><h2 id="quick-comparison" class="heading-section mt-3">Quick Comparison</h2>
    <div class="mt-7 hidden overflow-x-auto rounded-2xl border border-slate-200 md:block">
      <table class="w-full min-w-[900px] border-collapse bg-white text-left text-sm">
        <thead class="bg-slate-950 text-white"><tr>{['Kit', 'Best for', 'Platform', 'Learning focus', 'Project range', 'Primary action'].map((label) => <th scope="col" class="p-4 font-bold">{label}</th>)}</tr></thead>
        <tbody>{kits.map(({ product, profile }) => <tr class="border-t border-slate-200 align-top"><th scope="row" class="p-4 font-black text-slate-900">{profile.comparisonLabel}<span class="mt-1 block text-xs font-medium text-slate-500">{profile.verifiedProductInfo}</span></th><td class="p-4 leading-6 text-slate-700">{profile.bestFor}</td><td class="p-4 font-semibold text-slate-700">{product.platform}</td><td class="p-4 leading-6 text-slate-700">{profile.learningFocus}</td><td class="p-4 leading-6 text-slate-700">{profile.projectRange}</td><td class="p-4"><a href={`#${profile.comparisonLabel.toLowerCase()}`} class="text-link">View {profile.comparisonLabel} <Icon name="arrow-right" /></a></td></tr>)}</tbody>
      </table>
    </div>
    <div class="mt-7 grid gap-4 md:hidden">{kits.map(({ product, profile }) => <article class="rounded-2xl border border-slate-200 bg-white p-5"><h3 class="text-xl font-black text-slate-900">{profile.comparisonLabel}</h3><p class="mt-1 text-sm font-bold text-blue-700">{profile.verifiedProductInfo}</p><dl class="mt-4 space-y-3 text-sm"><div><dt class="font-bold text-slate-900">Best for</dt><dd class="mt-1 text-slate-600">{profile.bestFor}</dd></div><div><dt class="font-bold text-slate-900">Platform</dt><dd class="mt-1 text-slate-600">{product.platform}</dd></div><div><dt class="font-bold text-slate-900">Learning focus</dt><dd class="mt-1 text-slate-600">{profile.learningFocus}</dd></div></dl><a href={`#${profile.comparisonLabel.toLowerCase()}`} class="text-link mt-4">View {profile.comparisonLabel} <Icon name="arrow-right" /></a></article>)}</div>
  </section>

  <div class="mt-14 space-y-8">{kits.map(({ product, profile, active }) => (
    <section id={profile.comparisonLabel.toLowerCase()} aria-labelledby={`${product.id}-title`} class="scroll-mt-24 rounded-[var(--radius-card)] border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)] sm:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">{product.brand} · {product.platform} · {profile.verifiedProductInfo}</p>
      <h2 id={`${product.id}-title`} class="mt-3 text-3xl font-black text-slate-900">{profile.sectionTitle}</h2>
      <p class="mt-4 max-w-3xl leading-7 text-slate-600">{profile.explanation}</p>
      <div class="mt-7 grid gap-6 lg:grid-cols-2">
        {profile.selectedComponents && <div><h3 class="text-lg font-black text-slate-900">Selected components</h3><ul class="mt-4 grid gap-2 sm:grid-cols-2">{profile.selectedComponents.map((item) => <li class="flex gap-2 text-sm text-slate-700"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-700" />{item}</li>)}</ul></div>}
        <div><h3 class="text-lg font-black text-slate-900">{profile.selectedComponents ? 'Learning possibilities' : 'Selected learning areas'}</h3><ul class="mt-4 grid gap-2 sm:grid-cols-2">{profile.learningAreas.map((item) => <li class="flex gap-2 text-sm text-slate-700"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-blue-700" />{item}</li>)}</ul></div>
      </div>
      <div class="mt-7 grid gap-3 sm:grid-cols-2 lg:flex lg:flex-wrap">
        <Button href={`/products/${product.id}`} variant="secondary" class="w-full lg:w-auto">View {profile.comparisonLabel} Details</Button>
        {active && <div class="w-full sm:col-span-2 lg:w-auto"><BuyButtons links={product.affiliateLinks} preferredVendor="SunFounder" buttonLabel={`Get the ${profile.comparisonLabel} Kit`} activeOnly={true} /></div>}
        <Button href={profile.officialProductUrl} target="_blank" rel="noopener noreferrer" variant="secondary" class="w-full lg:w-auto" ariaLabel={`Open the official ${profile.comparisonLabel} product page (opens in a new tab)`}>Official product page</Button>
        <Button href={profile.officialDocumentationUrl} target="_blank" rel="noopener noreferrer" variant="secondary" class="w-full lg:w-auto" ariaLabel={`Open the official ${profile.comparisonLabel} documentation (opens in a new tab)`}>Official documentation</Button>
      </div>
      {active && <p class="mt-4 text-xs leading-5 text-slate-500">Affiliate link: Engineering Maker Lab may earn a commission at no additional cost to you.</p>}
    </section>
  ))}</div>

  <section aria-labelledby="choose-kit" class="mt-14 rounded-[var(--radius-card)] bg-slate-950 p-7 text-white sm:p-9">
    <h2 id="choose-kit" class="text-3xl font-black text-white">Which Pico Kit Should You Choose?</h2>
    <div class="mt-7 grid gap-4 md:grid-cols-3"><div class="rounded-2xl border border-white/10 bg-white/5 p-5"><h3 class="font-black text-white">Choose Thales if:</h3><p class="mt-2 text-sm leading-6 text-slate-300">You want the least complicated starting point.</p></div><div class="rounded-2xl border border-white/10 bg-white/5 p-5"><h3 class="font-black text-white">Choose Euler if:</h3><p class="mt-2 text-sm leading-6 text-slate-300">You want many more components and projects but do not need wireless features.</p></div><div class="rounded-2xl border border-white/10 bg-white/5 p-5"><h3 class="font-black text-white">Choose Kepler if:</h3><p class="mt-2 text-sm leading-6 text-slate-300">You want Wi-Fi, IoT, and Pico W projects.</p></div></div>
  </section>
  <div class="mt-10"><AffiliateDisclosure /></div>
</section>
