---
import Icon from './design-system/Icon.astro';
import DifficultyBadge from './DifficultyBadge.astro';

interface Props {
  title: string;
  description: string;
  tag: string;
  href: string;
}

const { title, description, tag, href } = Astro.props;
---

<article class="surface-card surface-card--interactive p-6">
  <DifficultyBadge level={tag} />
  <h3 class="mt-4 text-xl font-semibold text-slate-900">
    <a href={href} class="transition hover:text-blue-700">{title}</a>
  </h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>
  <a href={href} class="text-link mt-5">
    View project <Icon name="arrow-right" />
  </a>
</article>
