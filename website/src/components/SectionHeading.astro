---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  headingLevel?: 'h1' | 'h2';
}

const { eyebrow, title, description, headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;
---

<div class="max-w-3xl">
  <p class="eyebrow">{eyebrow}</p>
  <HeadingTag class="heading-section mt-3">{title}</HeadingTag>
  <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>
</div>
